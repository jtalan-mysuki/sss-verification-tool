PORT=3000

# Active LLM provider: openai | anthropic
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (optional — only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Google Gemini (optional — only needed if LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Upload limits
MAX_FILE_SIZE_MB=10

# Confidence threshold (0–1) to mark as "verified"
CONFIDENCE_THRESHOLD=0.7
